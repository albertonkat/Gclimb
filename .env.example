# Copy this file to .env and fill in your keys.
# Never commit .env to git.

# Claude orchestrator (required)
ANTHROPIC_API_KEY=sk-ant-...

# Codex subagent (required for code generation)
OPENAI_API_KEY=sk-...

# Gemini subagent — only required when using SDK backend (--mode sdk)
# For CLI backend (default): run `gemini auth login` once instead
GEMINI_API_KEY=AI...

# Optional model overrides
CLAUDE_MODEL=claude-sonnet-4-6
CODEX_MODEL=gpt-4o
GEMINI_MODEL=gemini-2.5-flash
